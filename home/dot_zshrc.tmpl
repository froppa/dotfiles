# ~/.zshrc
# Managed by chezmoi

# =======================================
# Environment
# =======================================
export LANG={{ .lang | quote }}
export LC_ALL={{ .lc_all | quote }}
export TERM="xterm-256color"
export EDITOR="vim"
export VISUAL="vim"
export LESS="--tabs=2 --no-init --LONG-PROMPT --ignore-case --quit-if-one-screen --RAW-CONTROL-CHARS"

# Go
export GOPATH="$HOME"
export GOBIN="$HOME/.local/bin"
export GO111MODULE="on"

# SSH
export SSH_KEY_PATH="$HOME/.ssh"

# =======================================
# PATH
# zsh-native, deduplicated, portable
# =======================================
typeset -U path PATH

path_prepend_if_exists() {
  local dir="$1"
  [[ -d "$dir" ]] && path=("$dir" $path)
}

path_prepend_if_exists "$HOME/.local/bin"
path_prepend_if_exists "$HOME/bin"
path_prepend_if_exists "$HOME/go/bin"
path_prepend_if_exists "$HOME/.cargo/bin"

export PATH

# =======================================
# History
# =======================================
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
HIST_STAMPS="yyyy-mm-dd"

setopt APPEND_HISTORY
setopt EXTENDED_HISTORY
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt HIST_SAVE_NO_DUPS
setopt HIST_IGNORE_SPACE

# =======================================
# Shell options
# =======================================
setopt AUTO_CD
setopt RM_STAR_SILENT
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_MINUS

# =======================================
# Prompt / theme
# =======================================
CASE_SENSITIVE="true"
ZSH_DISABLE_COMPFIX="true"
ZSH_THEME="simple"

# =======================================
# Oh My Zsh
# =======================================
export ZSH="$HOME/.oh-my-zsh"

plugins=(
{{- range .zsh.plugins }}
  {{ . }}
{{- end }}
)

if [[ -d "$ZSH" ]]; then
  source "$ZSH/oh-my-zsh.sh"
else
  autoload -Uz compinit
  compinit -d "$HOME/.zcompdump"
fi

# =======================================
# Aliases
# =======================================
alias g="git"

{{- if lookPath "fdfind" }}
alias fd="fdfind"
{{- end }}

{{- if lookPath "eza" }}
alias ls="eza"
{{- end }}

gpgkeys() {
  gpg -K --with-colons 2>/dev/null | awk -F: '$1 == "sec" { print $5 }'
}

# =======================================
# Agent helpers
# =======================================
if command -v gpgconf >/dev/null 2>&1; then
  gpgconf --launch gpg-agent >/dev/null 2>&1 || true
fi

{{- if eq .chezmoi.os "darwin" }}
if command -v ssh-add >/dev/null 2>&1; then
  if [[ -f "$HOME/.ssh/id_ed25519" ]] && ! /usr/bin/ssh-add -l >/dev/null 2>&1; then
    /usr/bin/ssh-add --apple-use-keychain "$HOME/.ssh/id_ed25519" >/dev/null 2>&1 || true
  fi
fi
{{- else }}
if [[ -z "${SSH_AUTH_SOCK:-}" ]] && command -v ssh-agent >/dev/null 2>&1; then
  eval "$(ssh-agent -s)" >/dev/null 2>&1
fi
{{- end }}

# =======================================
# Key bindings
# =======================================
bindkey "^a" beginning-of-line
bindkey "^e" end-of-line
bindkey "^f" forward-word
bindkey "^b" backward-word
bindkey "^k" kill-line
bindkey "^d" delete-char
bindkey "^w" backward-kill-word
bindkey "^u" backward-kill-line
bindkey "^R" history-incremental-pattern-search-backward
bindkey "^F" history-incremental-pattern-search-forward
bindkey "^i" expand-or-complete-prefix

# Alt-backspace / Ctrl-arrow compatibility
bindkey '^[^?' backward-kill-word
bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word

# =======================================
# NVM
# =======================================
{{- if stat (joinPath .chezmoi.homeDir ".nvm") }}
export NVM_DIR="$HOME/.nvm"

lazy_load_nvm() {
  [[ -s "$NVM_DIR/nvm.sh" ]] || return 1

  unset -f lazy_load_nvm nvm node npm npx yarn pnpm corepack
  source "$NVM_DIR/nvm.sh"
}

nvm() {
  lazy_load_nvm && nvm "$@"
}

node() {
  lazy_load_nvm && node "$@"
}

npm() {
  lazy_load_nvm && npm "$@"
}

npx() {
  lazy_load_nvm && npx "$@"
}

yarn() {
  lazy_load_nvm && yarn "$@"
}

pnpm() {
  lazy_load_nvm && pnpm "$@"
}

corepack() {
  lazy_load_nvm && corepack "$@"
}

[[ -f .nvmrc ]] && lazy_load_nvm >/dev/null 2>&1 || true
{{- end }}

# =======================================
# Local overrides
# =======================================
[[ -f "$HOME/.zsh_completions" ]] && source "$HOME/.zsh_completions"
[[ -f "$HOME/.zsh_completions.local" ]] && source "$HOME/.zsh_completions.local"
[[ -f "$HOME/.exports" ]] && source "$HOME/.exports"
[[ -f "$HOME/.exports.local" ]] && source "$HOME/.exports.local"
[[ -f "$HOME/.aliases" ]] && source "$HOME/.aliases"
[[ -f "$HOME/.functions" ]] && source "$HOME/.functions"
[[ -f "$HOME/.functions.local" ]] && source "$HOME/.functions.local"
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# =======================================
# Prompt
# Prefer starship if installed
# =======================================
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi
