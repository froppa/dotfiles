# ~/.aliases
# Managed by chezmoi

{{- if eq .chezmoi.os "linux" }}
export LS_COLORS='no=00:fi=00:di=01;31:ln=01;36:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arj=01;31:*.taz=01;31:*.lzh=01;31:*.zip=01;31:*.z=01;31:*.Z=01;31:*.gz=01;31:*.bz2=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.jpg=01;35:*.jpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.avi=01;35:*.fli=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.ogg=01;35:*.mp3=01;35:*.wav=01;35:'
{{- else if eq .chezmoi.os "darwin" }}
export LSCOLORS='BxBxhxDxfxhxhxhxhxcxcx'
{{- end }}

# =======================================
# Base aliases
# =======================================
if command -v grep >/dev/null 2>&1; then
  alias grep='grep --color=auto'
  alias egrep='egrep --color=auto'
fi

alias cls='clear'
alias d='dirs -v'
alias g='git'
alias dc='docker compose'
alias py='python3'
alias gitalias='git config --global --get-regexp "^alias\."'

if command -v highlight >/dev/null 2>&1; then
  alias ccat='highlight -O ansi'
fi

if command -v nvim >/dev/null 2>&1; then
  alias vi='nvim'
  alias vim='nvim'
  alias nano='nvim'
else
  alias vi='vim'
  alias nano='vim'
fi

if command -v eza >/dev/null 2>&1; then
  alias ls='eza'
  alias la='eza -a'
  alias ll='eza -lahH'
else
  {{- if eq .chezmoi.os "darwin" }}
  alias la='ls -aG'
  alias ll='ls -lahG'
  {{- else }}
  alias la='ls -a --color=auto'
  alias ll='ls -lah --color=auto'
  {{- end }}
fi

# Safer rm default is subjective. Verbose only.
alias rm='rm -v'

# =======================================
# Chezmoi / dotfiles helpers
# =======================================
alias reloadzsh='source ~/.zshrc'
alias dotapply='chezmoi apply -v'
alias dotdiff='chezmoi diff'
alias dotstatus='chezmoi status'

alias confzsh='chezmoi edit --apply ~/.zshrc'
alias confzshl='${EDITOR:-nvim} ~/.zshrc.local'
alias confalias='chezmoi edit --apply ~/.aliases'
alias confaliasl='${EDITOR:-nvim} ~/.aliases.local'
alias confexports='chezmoi edit --apply ~/.exports'
alias confexportsl='${EDITOR:-nvim} ~/.exports.local'
alias conffunctionsl='${EDITOR:-nvim} ~/.functions.local'
alias confgit='chezmoi edit --apply ~/.gitconfig'
alias confgitl='${EDITOR:-nvim} ~/.gitconfig.local'
alias confzcompl='chezmoi edit --apply ~/.zsh_completions'
alias confzcompll='${EDITOR:-nvim} ~/.zsh_completions.local'
alias conftmux='chezmoi edit --apply ~/.tmux.conf'

# =======================================
# Navigation
# =======================================
alias gocode='cd ~/code'

pu() {
  pushd "$1" >/dev/null || return 1
  dirs -v
}

po() {
  popd >/dev/null || return 1
  dirs -v
}

for i in {1..9}; do
  alias "$i"="pushd -$i >/dev/null && dirs -v"
done

# =======================================
# IP / network helpers
# =======================================
ip() {
  if command -v dig >/dev/null 2>&1; then
    dig +short myip.opendns.com @resolver1.opendns.com
  elif command -v curl >/dev/null 2>&1; then
    curl -fsSL https://api.ipify.org
  else
    echo "No dig or curl available" >&2
    return 1
  fi
}

localip() {
  {{- if eq .chezmoi.os "darwin" }}
  ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null
  {{- else }}
  hostname -I 2>/dev/null | awk '{print $1}'
  {{- end }}
}

ips() {
  if command -v ip >/dev/null 2>&1; then
    ip -o addr show | awk '{print $4}'
  else
    ifconfig -a | awk '/inet /{print $2} /inet6 /{print $2}'
  fi
}

ifactive() {
  {{- if eq .chezmoi.os "darwin" }}
  ifconfig | awk '
    /^[a-z0-9]/ { iface=$1; sub(":","",iface) }
    /status: active/ { print iface }
  '
  {{- else }}
  ip -br link show up 2>/dev/null || ifconfig
  {{- end }}
}

{{- if eq .chezmoi.os "darwin" }}
flush() {
  dscacheutil -flushcache
  killall -HUP mDNSResponder
}

lscleanup() {
  /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
    -kill -r -domain local -domain system -domain user && killall Finder
}

alias brewup='brew update && brew upgrade && brew cleanup'
alias update='sudo softwareupdate -i -a && brew update && brew upgrade && brew cleanup && npm install -g npm && npm update -g'
alias cleanup="find . -type f -name '*.DS_Store' -ls -delete"
alias afk='/System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend'
{{- else }}
flush() {
  if command -v resolvectl >/dev/null 2>&1; then
    sudo resolvectl flush-caches
  elif command -v systemd-resolve >/dev/null 2>&1; then
    sudo systemd-resolve --flush-caches
  else
    echo "No supported DNS cache flush command found" >&2
    return 1
  fi
}
{{- end }}

[[ -f "$HOME/.aliases.local" ]] && source "$HOME/.aliases.local"
